{
    "camera": {
        "backend": "USB",
        "usb_device_id": 0,
        "basler_device_id": "",
        "hikvision_device_id": "",
        "resolution": { "width": 1920, "height": 1080 },
        "fps": 30,
        "acquisition_timeout_ms": 2000,
        "auto_reconnect": true,
        "reconnect_interval_ms": 5000,
        "reconnect_max_retries": 5
    },
    "halcon": {
        "license_mode": "auto",
        "license_server": "",
        "template_path": "resources/templates/",
        "match": {
            "min_score": 0.7,
            "max_targets": 16,
            "rotation_start_deg": -180.0,
            "rotation_extent_deg": 360.0
        }
    },
    "calibration": {
        "pattern_rows": 7,
        "pattern_cols": 7,
        "square_size_mm": 6.0,
        "pixel_equivalent_mm": 0.05,
        "reprojection_error_max_px": 0.5,
        "min_calib_poses": 15
    },
    "robot": {
        "ip": "127.0.0.1",
        "port": 5000,
        "connection_timeout_ms": 3000,
        "heartbeat_interval_ms": 1000,
        "allowed_ip_whitelist": ["127.0.0.1"],
        "workspace": {
            "x_min_mm": -500.0,
            "x_max_mm": 500.0,
            "y_min_mm": -500.0,
            "y_max_mm": 500.0
        }
    },
    "database": {
        "path": "data/robot_vision.db",
        "backup_enabled": true,
        "retention_days": 90
    },
    "report": {
        "export_path": "exports/",
        "csv_encoding": "UTF-8-BOM",
        "pdf_page_size": "A4"
    },
    "ui": {
        "language": "zh_CN",
        "theme": "Fusion",
        "log_max_lines": 5000,
        "auto_save_settings": true
    }
}
